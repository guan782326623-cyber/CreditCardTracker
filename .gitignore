# Build output
dist/
build/
*.spec.bak

# Release artifacts (distribute via GitHub Releases, not git)
*.exe
*.zip

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
.eggs/

# PyInstaller temp
AmexTrackerBuild/
CardTrackerBuild/

# Database (user personal data — do NOT commit)
*.db
*.sqlite
*.sqlite3

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE / tooling
.vscode/
.idea/
.claude/
*.swp
*.swo

# Logs
*.log

# AI workspace inbox folders — routed content is not tracked (only .gitkeep stays)
_INBOX_RAW/*
!_INBOX_RAW/.gitkeep
_INBOX_PROCESSED/*
!_INBOX_PROCESSED/.gitkeep
_INBOX_IGNORED/*
!_INBOX_IGNORED/.gitkeep
